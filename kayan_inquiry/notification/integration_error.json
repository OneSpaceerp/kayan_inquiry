  "name": "Inquiry Integration Error",
  "enabled": 1,
  "channel": "Email",
  "send_system_notification": 1,
  "document_type": "Email Inquiry Ticket",
  "event": "Custom",
  "method": "kayan_inquiry.kayan_inquiry.notification.integration_error.trigger_integration_error_notification",
  "condition": "",
