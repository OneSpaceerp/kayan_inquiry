{
  "doctype": "Notification",
  "docstatus": 0,
  "name": "Ticket Lost Notification",
  "enabled": 1,
  "channel": "System Notification",
  "send_system_notification": 1,
  "document_type": "Email Inquiry Ticket",
  "event": "Value Change",
  "value_changed": "workflow_state",
  "condition": "doc.workflow_state == 'Lost / Closed'",
  "recipients": [
    {
      "doctype": "Notification Recipient",
      "receiver_by_role": "Inquiry Sales Manager"
    }
  ],
  "subject": "[Lost] {{ doc.name }} \u2014 {{ doc.email_subject }}",
  "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 640px; margin: 0 auto;\">\n  <div style=\"background: #616161; color: #ffffff; padding: 16px 24px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"margin: 0; font-size: 18px;\">Inquiry Lost / Closed</h2>\n  </div>\n  <div style=\"background: #ffffff; padding: 24px; border: 1px solid #e0e0e0;\">\n    <p style=\"margin: 0 0 16px; color: #333;\">An inquiry ticket has been marked as lost or closed. Please review the details and lost reason for pipeline analytics.</p>\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f5f5f5; border: 1px solid #e0e0e0; font-weight: 600; width: 35%; color: #555;\">Ticket ID</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.name }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f5f5f5; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Subject</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.email_subject }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f5f5f5; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Company</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.company_name or 'N/A' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f5f5f5; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Sales Engineer</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.assigned_sales_engineer }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f5f5f5; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Lost Reason</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #d32f2f; font-weight: 600;\">{{ doc.lost_reason or 'Not specified' }}</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin-top: 20px;\">\n      <a href=\"{{ frappe.utils.get_url_to_form('Email Inquiry Ticket', doc.name) }}\" style=\"display: inline-block; background: #616161; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px;\">View Ticket</a>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 12px 24px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #888;\">Kayan Inquiry Management System</p>\n  </div>\n</div>",
  "attach_print": 0,
  "module": "Kayan Inquiry",
  "creation": "2026-05-19 00:00:00.000000",
  "modified": "2026-05-19 00:00:00.000000",
  "owner": "Administrator",
  "modified_by": "Administrator"
}
