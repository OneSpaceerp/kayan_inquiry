{
  "doctype": "Notification",
  "docstatus": 0,
  "name": "Ticket Won Notification",
  "enabled": 1,
  "channel": "System Notification",
  "send_system_notification": 1,
  "document_type": "Email Inquiry Ticket",
  "event": "Value Change",
  "value_changed": "workflow_state",
  "condition": "doc.workflow_state == 'Won: Sales Order Generated'",
  "recipients": [
    {
      "doctype": "Notification Recipient",
      "receiver_by_document_field": "assigned_sales_engineer"
    },
    {
      "doctype": "Notification Recipient",
      "receiver_by_role": "Inquiry Sales Manager"
    }
  ],
  "subject": "\ud83c\udf89 [Won] {{ doc.name }} \u2014 {{ doc.email_subject }}",
  "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 640px; margin: 0 auto;\">\n  <div style=\"background: linear-gradient(135deg, #1b5e20, #4caf50); color: #ffffff; padding: 20px 24px; border-radius: 8px 8px 0 0; text-align: center;\">\n    <h2 style=\"margin: 0; font-size: 22px;\">\ud83c\udf89 Inquiry Won!</h2>\n    <p style=\"margin: 8px 0 0; opacity: 0.9; font-size: 14px;\">A sales order has been generated from this inquiry.</p>\n  </div>\n  <div style=\"background: #ffffff; padding: 24px; border: 1px solid #e0e0e0;\">\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n      <tr>\n        <td style=\"padding: 8px 12px; background: #e8f5e9; border: 1px solid #c8e6c9; font-weight: 600; width: 35%; color: #2e7d32;\">Ticket ID</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #c8e6c9; color: #333;\">{{ doc.name }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #e8f5e9; border: 1px solid #c8e6c9; font-weight: 600; color: #2e7d32;\">Subject</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #c8e6c9; color: #333;\">{{ doc.email_subject }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #e8f5e9; border: 1px solid #c8e6c9; font-weight: 600; color: #2e7d32;\">Company</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #c8e6c9; color: #333;\">{{ doc.company_name or 'N/A' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #e8f5e9; border: 1px solid #c8e6c9; font-weight: 600; color: #2e7d32;\">Sales Engineer</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #c8e6c9; color: #333;\">{{ doc.assigned_sales_engineer }}</td>\n      </tr>\n      {% if doc.linked_quotation %}\n      <tr>\n        <td style=\"padding: 8px 12px; background: #e8f5e9; border: 1px solid #c8e6c9; font-weight: 600; color: #2e7d32;\">Linked Quotation</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #c8e6c9; color: #333;\"><a href=\"{{ frappe.utils.get_url_to_form('Quotation', doc.linked_quotation) }}\">{{ doc.linked_quotation }}</a></td>\n      </tr>\n      {% endif %}\n    </table>\n    <div style=\"text-align: center; margin-top: 20px;\">\n      <a href=\"{{ frappe.utils.get_url_to_form('Email Inquiry Ticket', doc.name) }}\" style=\"display: inline-block; background: #2e7d32; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px;\">View Ticket</a>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 12px 24px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #888;\">Kayan Inquiry Management System</p>\n  </div>\n</div>",
  "attach_print": 0,
  "module": "Kayan Inquiry",
  "creation": "2026-05-19 00:00:00.000000",
  "modified": "2026-05-19 00:00:00.000000",
  "owner": "Administrator",
  "modified_by": "Administrator"
}
