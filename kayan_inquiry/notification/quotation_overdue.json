{
  "doctype": "Notification",
  "docstatus": 0,
  "name": "Quotation Overdue Alert",
  "enabled": 1,
  "channel": "Email",
  "send_system_notification": 0,
  "document_type": "Email Inquiry Ticket",
  "event": "Value Change",
  "value_changed": "sla_status",
  "condition": "doc.workflow_state == 'Quotation Preparation' and doc.sla_status == 'Breached'",
  "recipients": [
    {
      "doctype": "Notification Recipient",
      "receiver_by_role": "Inquiry Sales Manager"
    }
  ],
  "subject": "[Quotation Overdue] {{ doc.name }} \u2014 {{ doc.email_subject }}",
  "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 640px; margin: 0 auto;\">\n  <div style=\"background: #c62828; color: #ffffff; padding: 16px 24px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"margin: 0; font-size: 18px;\">\u23f0 Quotation Overdue \u2014 SLA Breached</h2>\n  </div>\n  <div style=\"background: #ffffff; padding: 24px; border: 1px solid #e0e0e0;\">\n    <div style=\"background: #ffebee; border-left: 4px solid #c62828; padding: 12px 16px; margin-bottom: 16px; border-radius: 0 4px 4px 0;\">\n      <strong style=\"color: #b71c1c;\">Quotation delivery is overdue.</strong>\n      <p style=\"margin: 8px 0 0; color: #333;\">This ticket has been in the \"Quotation Preparation\" stage and has breached its SLA. Management intervention may be required.</p>\n    </div>\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; width: 35%; color: #555;\">Ticket ID</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.name }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Subject</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.email_subject }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Assigned SE</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.assigned_sales_engineer }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Company</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.company_name or 'N/A' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Priority</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.priority or 'Medium' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">SLA Due</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #d32f2f; font-weight: 700;\">{{ frappe.utils.format_datetime(doc.sla_due_datetime) if doc.sla_due_datetime else 'Not Set' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Current Stage</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">Quotation Preparation</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin-top: 20px;\">\n      <a href=\"{{ frappe.utils.get_url_to_form('Email Inquiry Ticket', doc.name) }}\" style=\"display: inline-block; background: #c62828; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px;\">Review Ticket</a>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 12px 24px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #888;\">Kayan Inquiry Management System \u2014 Quotation Monitoring</p>\n  </div>\n</div>",
  "attach_print": 0,
  "module": "Kayan Inquiry",
  "creation": "2026-05-19 00:00:00.000000",
  "modified": "2026-05-19 00:00:00.000000",
  "owner": "Administrator",
  "modified_by": "Administrator"
}
