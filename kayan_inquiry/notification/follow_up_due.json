{
  "doctype": "Notification",
  "docstatus": 0,
  "name": "Inquiry Follow-Up Due",
  "enabled": 1,
  "channel": "Email",
  "send_system_notification": 1,
  "document_type": "Inquiry Follow-Up",
  "event": "Days Before",
  "days_in_advance": 0,
  "date_changed": "due_date",
  "condition": "doc.completed == 0",
  "recipients": [
    {
      "doctype": "Notification Recipient",
      "receiver_by_document_field": "owner"
    }
  ],
  "subject": "[Follow-Up Due] {{ doc.ticket }} \u2014 {{ doc.follow_up_type }}",
  "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 640px; margin: 0 auto;\">\n  <div style=\"background: #0277bd; color: #ffffff; padding: 16px 24px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"margin: 0; font-size: 18px;\">\ud83d\udcc5 Follow-Up Due Today</h2>\n  </div>\n  <div style=\"background: #ffffff; padding: 24px; border: 1px solid #e0e0e0;\">\n    <div style=\"background: #e1f5fe; border-left: 4px solid #0277bd; padding: 12px 16px; margin-bottom: 16px; border-radius: 0 4px 4px 0;\">\n      <strong style=\"color: #01579b;\">You have a follow-up action due today.</strong>\n      <p style=\"margin: 8px 0 0; color: #333;\">Please complete the scheduled follow-up for this inquiry ticket.</p>\n    </div>\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; width: 35%; color: #555;\">Ticket</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.ticket }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Follow-Up Type</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.follow_up_type }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Due Date</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #0277bd; font-weight: 600;\">{{ frappe.utils.format_date(doc.due_date) }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Notes</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.notes or 'No notes added' }}</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin-top: 20px;\">\n      <a href=\"{{ frappe.utils.get_url_to_form('Email Inquiry Ticket', doc.ticket) }}\" style=\"display: inline-block; background: #0277bd; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px; margin-right: 8px;\">Open Ticket</a>\n      <a href=\"{{ frappe.utils.get_url_to_form('Inquiry Follow-Up', doc.name) }}\" style=\"display: inline-block; background: #ffffff; color: #0277bd; padding: 9px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px; border: 2px solid #0277bd;\">Open Follow-Up</a>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 12px 24px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #888;\">Kayan Inquiry Management System \u2014 Follow-Up Reminders</p>\n  </div>\n</div>",
  "attach_print": 0,
  "module": "Kayan Inquiry",
  "creation": "2026-05-19 00:00:00.000000",
  "modified": "2026-05-19 00:00:00.000000",
