{
  "doctype": "Notification",
  "docstatus": 0,
  "name": "SLA Breach Warning",
  "enabled": 1,
  "channel": "Email",
  "send_system_notification": 1,
  "document_type": "Email Inquiry Ticket",
  "event": "Value Change",
  "value_changed": "sla_status",
  "condition": "doc.sla_status in ('At Risk', 'Breached')",
  "recipients": [
    {
      "doctype": "Notification Recipient",
      "receiver_by_document_field": "assigned_sales_engineer"
    },
    {
      "doctype": "Notification Recipient",
      "receiver_by_role": "Inquiry Sales Manager"
    }
  ],
  "subject": "[SLA {{ doc.sla_status }}] {{ doc.name }} \u2014 {{ doc.email_subject }}",
  "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 640px; margin: 0 auto;\">\n  <div style=\"background: {% if doc.sla_status == 'Breached' %}#d32f2f{% else %}#f57c00{% endif %}; color: #ffffff; padding: 16px 24px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"margin: 0; font-size: 18px;\">\u26a0\ufe0f SLA {{ doc.sla_status }} \u2014 Immediate Action Required</h2>\n  </div>\n  <div style=\"background: #ffffff; padding: 24px; border: 1px solid #e0e0e0;\">\n    <div style=\"background: {% if doc.sla_status == 'Breached' %}#ffebee{% else %}#fff3e0{% endif %}; border-left: 4px solid {% if doc.sla_status == 'Breached' %}#d32f2f{% else %}#f57c00{% endif %}; padding: 12px 16px; margin-bottom: 16px; border-radius: 0 4px 4px 0;\">\n      <strong style=\"color: {% if doc.sla_status == 'Breached' %}#b71c1c{% else %}#e65100{% endif %}; font-size: 15px;\">SLA Status: {{ doc.sla_status }}</strong>\n      <p style=\"margin: 8px 0 0; color: #333;\">{% if doc.sla_status == 'Breached' %}The SLA for this ticket has been breached. Escalate immediately.{% else %}This ticket is at risk of breaching its SLA. Please take action now.{% endif %}</p>\n    </div>\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; width: 35%; color: #555;\">Ticket ID</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.name }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Subject</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.email_subject }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Assigned To</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.assigned_sales_engineer }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Priority</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">\n          <span style=\"font-weight: 700; color: {% if doc.priority == 'Urgent' %}#d32f2f{% elif doc.priority == 'High' %}#e65100{% else %}#333{% endif %};\">{{ doc.priority or 'Medium' }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Current Stage</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.workflow_state }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">SLA Due</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333; font-weight: 700; color: {% if doc.sla_status == 'Breached' %}#d32f2f{% else %}#f57c00{% endif %};\">{{ frappe.utils.format_datetime(doc.sla_due_datetime) if doc.sla_due_datetime else 'Not Set' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; background: #f8f9fa; border: 1px solid #e0e0e0; font-weight: 600; color: #555;\">Company</td>\n        <td style=\"padding: 8px 12px; border: 1px solid #e0e0e0; color: #333;\">{{ doc.company_name or 'N/A' }}</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin-top: 20px;\">\n      <a href=\"{{ frappe.utils.get_url_to_form('Email Inquiry Ticket', doc.name) }}\" style=\"display: inline-block; background: {% if doc.sla_status == 'Breached' %}#d32f2f{% else %}#f57c00{% endif %}; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 14px;\">View Ticket Immediately</a>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 12px 24px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #888;\">Kayan Inquiry Management System \u2014 SLA Monitoring</p>\n  </div>\n</div>",
  "attach_print": 0,
  "module": "Kayan Inquiry",
  "creation": "2026-05-19 00:00:00.000000",
  "modified": "2026-05-19 00:00:00.000000",
  "owner": "Administrator",
  "modified_by": "Administrator"
}
